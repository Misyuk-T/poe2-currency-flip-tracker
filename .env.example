# Copy to .env and adjust. NEVER commit a real .env or any secret.

# HTTP port
PORT=8080

# Data source: "fixture" (default, offline, safe) or "live" (EXPERIMENTAL GGG).
# Live mode calls an undocumented, unapproved GGG endpoint. See README.
PROVIDER_MODE=fixture
TIERED_SCHEDULER=true
MARKET_CATEGORIES=Currency,Fragments,Essences
WARM_BATCH_SIZE=4
COLD_BATCH_SIZE=4
WARM_INTERVAL_MS=900000
COLD_INTERVAL_MS=3600000
MAX_TRACKED_TARGETS=250

# Game / realm / league. No seasonal league is hardcoded; override freely.
POE_GAME=poe2
POE_REALM=poe2
LEAGUE=Runes of Aldur

# Anchor currency (everything is priced as anchor-per-target).
ANCHOR_CURRENCY=exalted

# Manual shortlist of target currency ids (comma-separated). Targets without a
# verified gold cost (e.g. `vaal`) are surfaced as a coverage gap at startup and
# shown as UNRANKABLE — never guessed. `vaal` is included on purpose to
# demonstrate that honest path; drop it for an all-rankable default.
SHORTLIST=divine,chaos,vaal

# Background poll interval (ms). Safe default: 5 minutes.
POLL_INTERVAL_MS=300000

# Listings older than this (ms) are flagged stale. Default: 15 minutes.
MAX_LISTING_AGE_MS=900000

# Live request batching for `want` items (3-5 recommended; >10 rejected).
BATCH_SIZE=4

# Identify yourself politely to GGG when in live mode.
USER_AGENT=poe2-currency-flip-tracker/0.1 (experimental; non-commercial)
CONTACT_EMAIL=

# Optional session cookie for live mode. Server-side ONLY; never exposed to the
# browser. Leave blank unless you understand the legal/ToS implications.
POESESSID=

# --- A3: backend-controlled polling / API protection ---

# Token for the protected admin force-refresh endpoint (POST /admin/refresh,
# header `x-admin-token`). Leave blank to DISABLE the endpoint entirely — users
# can then never force a provider fetch. Server-side only.
ADMIN_TOKEN=

# Only trust X-Forwarded-For for client IPs when behind a known proxy.
TRUST_PROXY=false

# Per-IP frontend API rate limit (sliding window).
API_RATE_LIMIT_PER_MIN=120
API_RATE_WINDOW_MS=60000

# Circuit breaker around the provider: after N consecutive failures stop hitting
# it and back off exponentially (base -> max).
CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_COOLDOWN_BASE_MS=30000
CIRCUIT_COOLDOWN_MAX_MS=300000

# Reject query strings longer than this many characters.
MAX_QUERY_LENGTH=2048

# --- Phase B: storage ---

# "local" (default, zero-dep JSONL under .data/) or "supabase" (durable Postgres).
STORAGE=local

# Supabase Postgres connection string (server-side ONLY; never in the browser).
# Required when STORAGE=supabase; also run `npm install postgres`. Prefer a
# least-privilege role (SELECT/INSERT on snapshot_runs+market_points). Use the
# Supabase pooler URL; the adapter sets prepare:false + ssl:require.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:6543/postgres
DATABASE_URL=
